# 🔹 6) Modelo 2D com Acoplamento

```python
def simulate_2d(xi, T, coupling=0.5):
    x, y = 0.1, -0.1
    xs, ys = [], []

    for _ in range(T):
        drift_x = -dU_dx(x, xi) + coupling*(y - x)
        drift_y = -dU_dx(y, xi) + coupling*(x - y)

        x += drift_x*dt + sigma*np.sqrt(dt)*np.random.randn()
        y += drift_y*dt + sigma*np.sqrt(dt)*np.random.randn()

        xs.append(x)
        ys.append(y)

    return np.array(xs), np.array(ys)

x2, y2 = simulate_2d(1.0, 20000)

