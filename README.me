def estimate_fp(x):
    dx = np.diff(x)
    x_mid = x[:-1]

    bins = np.linspace(np.min(x), np.max(x), 40)
    digitized = np.digitize(x_mid, bins)

    drift_est = []
    diff_est = []
    centers = []

    for i in range(1, len(bins)):
        mask = digitized == i
        if np.sum(mask) > 20:
            drift_est.append(np.mean(dx[mask]) / dt)
            diff_est.append(np.var(dx[mask]) / dt)
            centers.append((bins[i] + bins[i-1]) / 2)

    return np.array(centers), np.array(drift_est), np.array(diff_est)

