# 🔹 11) Mean-Field Ising Econômico

```python
def simulate_ising(N=200, J=1.0, beta=1.0, steps=200):
    spins = np.random.choice([-1,1], size=N)
    magnetizations = []

    for _ in range(steps):
        m = np.mean(spins)

        for i in range(N):
            h = J*m
            prob = 1/(1+np.exp(-2*beta*h))
            spins[i] = 1 if np.random.rand()<prob else -1

        magnetizations.append(np.mean(spins))

    return np.array(magnetizations)

mags = simulate_ising()

plt.figure()
plt.plot(mags)
plt.title("Magnetização Ising Econômico")
plt.show()
