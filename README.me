# GLOBAL METRICS
# ============================================================

print("\n=== GLOBAL STATISTICS ===")

mean_ret = np.mean(returns)
std_ret = np.std(returns)
var_ret = np.var(returns)
skew = stats.skew(returns)
kurt = stats.kurtosis(returns)

hurst_global = hurst_exponent(returns)
autocorr_global = lag1_autocorr(returns)
jb_stat, jb_p = stats.jarque_bera(returns)
tail_index = hill_tail_index(returns, TAIL_K)

print("Mean return:", mean_ret)
print("Std deviation:", std_ret)
print("Variance:", var_ret)
print("Skewness:", skew)
print("Excess kurtosis:", kurt)
print("Hurst exponent:", hurst_global)
print("Lag-1 autocorrelation:", autocorr_global)
print("Jarque-Bera statistic:", jb_stat)
print("Jarque-Bera p-value:", jb_p)
print("Hill tail index:", tail_index)

# ============================================================
# DIFFUSION MATRIX ESTIMATION
# ============================================================

D = estimate_diffusion_matrix(returns)

print("\n=== DIFFUSION MATRIX ===")
print(D)

# ============================================================
# POTENTIAL RECONSTRUCTION
# ============================================================

centers, U = reconstruct_potential(returns)

print("\n=== POTENTIAL METRICS ===")
print("Potential mean:", np.mean(U))
print("Potential max:", np.max(U))
print("Potential min:", np.min(U))

# ============================================================
# ROLLING METRICS
# ============================================================

print("\n=== ROLLING METRICS ===")

rolling_var = []
rolling_hurst = []
rolling_autocorr = []

for i in range(ROLLING_WINDOW, len(returns)):
    window = returns[i-ROLLING_WINDOW:i]
    rolling_var.append(np.var(window))
    rolling_hurst.append(hurst_exponent(window))
    rolling_autocorr.append(lag1_autocorr(window))

rolling_var = np.array(rolling_var)
rolling_hurst = np.array(rolling_hurst)
rolling_autocorr = np.array(rolling_autocorr)

rolling_xi = adaptive_xi(rolling_var)

print("Rolling variance mean:", np.nanmean(rolling_var))
print("Rolling variance max:", np.nanmax(rolling_var))
print("Rolling variance min:", np.nanmin(rolling_var))

print("Rolling Hurst mean:", np.nanmean(rolling_hurst))
print("Rolling Hurst max:", np.nanmax(rolling_hurst))
print("Rolling Hurst min:", np.nanmin(rolling_hurst))

print("Rolling autocorr mean:", np.nanmean(rolling_autocorr))
print("Rolling autocorr max:", np.nanmax(rolling_autocorr))
print("Rolling autocorr min:", np.nanmin(rolling_autocorr))

print("Adaptive xi mean:", np.nanmean(rolling_xi))
print("Adaptive xi max:", np.nanmax(rolling_xi))
print("Adaptive xi min:", np.nanmin(rolling_xi))

# ============================================================
# META-STABILITY DIAGNOSTIC SCORE
# ============================================================

meta_score = (
    0.4 * np.nanmean(rolling_hurst) +
    0.3 * np.nanmean(rolling_autocorr) +
    0.3 * (1 / (1 + np.nanmean(rolling_var)))
)

print("\n=== META-STABILITY SCORE ===")
print("Composite instability score:", meta_score)

print("\n=== EXPERIMENT COMPLETE ===")
