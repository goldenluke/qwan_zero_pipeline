# 🔹 9) Hurst Exponent

```python
def hurst_exponent(ts):
    N = len(ts)
    T_vals = np.arange(10, N//2, 50)
    RS = []

    for T in T_vals:
        n_segments = N // T
        R_S_vals = []

        for i in range(n_segments):
            segment = ts[i*T:(i+1)*T]
            mean = np.mean(segment)
            Z = np.cumsum(segment - mean)
            R = np.max(Z) - np.min(Z)
            S = np.std(segment)
            if S > 0:
                R_S_vals.append(R/S)

        if len(R_S_vals) > 0:
            RS.append(np.mean(R_S_vals))

    logT = np.log(T_vals[:len(RS)])
    logRS = np.log(RS)

    slope = np.polyfit(logT, logRS, 1)[0]
    return slope

print("Hurst:", hurst_exponent(x2))
```

