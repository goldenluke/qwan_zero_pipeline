def estimate_diffusion_matrix(x, y):
    dx = np.diff(x)
    dy = np.diff(y)

    Dxx = np.var(dx)/dt
    Dyy = np.var(dy)/dt
    Dxy = np.cov(dx, dy)[0,1]/dt

    return np.array([[Dxx, Dxy],
                     [Dxy, Dyy]])

